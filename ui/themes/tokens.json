{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "Browser 2030B design tokens (UI/UX spec §1). Light/dark aware, WCAG AA contrast.",
  "color": {
    "bg": {
      "light": { "$value": "#ffffff", "$type": "color" },
      "dark": { "$value": "#1b1b1f", "$type": "color" }
    },
    "fg": {
      "light": { "$value": "#1b1b1f", "$type": "color" },
      "dark": { "$value": "#e6e6ee", "$type": "color" }
    },
    "accent": {
      "light": { "$value": "#1a73e8", "$type": "color" },
      "dark": { "$value": "#8ab4f8", "$type": "color" }
    },
    "danger": { "$value": "#d93025", "$type": "color" },
    "success": { "$value": "#188038", "$type": "color" }
  },
  "space": {
    "xs": { "$value": "4px", "$type": "dimension" },
    "sm": { "$value": "8px", "$type": "dimension" },
    "md": { "$value": "12px", "$type": "dimension" },
    "lg": { "$value": "16px", "$type": "dimension" },
    "xl": { "$value": "24px", "$type": "dimension" }
  },
  "radius": {
    "sm": { "$value": "6px", "$type": "dimension" },
    "md": { "$value": "10px", "$type": "dimension" },
    "pill": { "$value": "999px", "$type": "dimension" }
  },
  "font": {
    "ui": { "$value": "system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif", "$type": "fontFamily" },
    "mono": { "$value": "'SF Mono', 'Cascadia Code', Consolas, monospace", "$type": "fontFamily" }
  },
  "motion": {
    "fast": { "$value": "120ms", "$type": "duration" },
    "base": { "$value": "200ms", "$type": "duration" }
  }
}
