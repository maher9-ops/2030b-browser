{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Browser 2030B",
  "mainBinaryName": "Browser 2030B",
  "version": "0.1.0",
  "identifier": "ai.b2030b.shell",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "yarn dev",
    "beforeBuildCommand": "yarn build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Browser 2030B",
        "width": 1280,
        "height": 800,
        "minWidth": 720,
        "minHeight": 480,
        "decorations": false,
        "transparent": true,
        "theme": null,
        "center": true,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": "default-src 'none'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost; worker-src 'self' blob:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "deb", "rpm", "msi", "nsis"],
    "category": "Network",
    "icon": [
      "icons/icon.ico",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.png"
    ],
    "shortDescription": "Browser 2030B — privacy-first, default-deny browser",
    "longDescription": "Browser 2030B (b2030b): a memory-safe, default-deny, post-quantum-ready browser shell with an intent-first command palette, vertical Spaces, an AI copilot overlay, and privacy-as-UX."
  }
}
