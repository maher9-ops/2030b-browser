{
  "name": "@b2030b/shell-desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "yarn workspace @b2030b/command-palette build && vite",
    "build": "yarn workspace @b2030b/command-palette build && tsc -p tsconfig.json && vite build",
    "typecheck": "yarn workspace @b2030b/command-palette build && tsc -p tsconfig.json --noEmit",
    "preview": "vite preview",
    "test": "vitest run",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@b2030b/command-palette": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
