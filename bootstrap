#!/usr/bin/env sh
# Browser 2030B — bootstrap
# Codename: b2030b
#
# Prepares a developer or CI machine to build Browser 2030B. It is idempotent:
# re-running only installs what is missing. Default-deny networking principle
# does not apply to the toolchain bootstrap itself, but every fetch is pinned.
#
# Usage:  ./bootstrap            # full toolchain + upstream engine fetch
#         ./bootstrap --no-engine   # skip the multi-GB Chromium/Gecko fetch
#         ./bootstrap --check       # verify environment only, install nothing
#
# POSIX shell. A PowerShell equivalent lives at ./bootstrap.ps1 for Windows.

set -eu

ROOT="$(cd "$(dirname "$0")" && pwd)"
FETCH_ENGINE=1
CHECK_ONLY=0

for arg in "$@"; do
    case "$arg" in
        --no-engine) FETCH_ENGINE=0 ;;
        --check)     CHECK_ONLY=1 ;;
        -h|--help)
            grep '^#' "$0" | sed 's/^# \{0,1\}//'
            exit 0
            ;;
        *) echo "bootstrap: unknown argument '$arg'" >&2; exit 2 ;;
    esac
done

log()  { printf '\033[1;36m[bootstrap]\033[0m %s\n' "$*"; }
warn() { printf '\033[1;33m[bootstrap]\033[0m %s\n' "$*" >&2; }
die()  { printf '\033[1;31m[bootstrap]\033[0m %s\n' "$*" >&2; exit 1; }
have() { command -v "$1" >/dev/null 2>&1; }

UNAME="$(uname -s)"
log "Detected platform: $UNAME"

# ---------------------------------------------------------------------------
# 1. Rust toolchain (engine, net, policy, ipc, ai, sync).
# ---------------------------------------------------------------------------
ensure_rust() {
    if have rustup; then
        log "rustup present; syncing pinned toolchain from rust-toolchain.toml"
        [ "$CHECK_ONLY" -eq 1 ] || rustup show >/dev/null 2>&1 || true
        return
    fi
    [ "$CHECK_ONLY" -eq 1 ] && { warn "rustup missing (check-only)"; return; }
    log "Installing rustup (pinned channel 1.82)"
    curl --proto '=https' --tlsv1.3 -sSf https://sh.rustup.rs \
        | sh -s -- -y --default-toolchain 1.82 --profile default
    # shellcheck disable=SC1091
    . "$HOME/.cargo/env"
}

# ---------------------------------------------------------------------------
# 2. Node + Corepack (UI shell, devtools, cloud wasm edition).
# ---------------------------------------------------------------------------
ensure_node() {
    if have node; then
        log "node present: $(node --version)"
    else
        [ "$CHECK_ONLY" -eq 1 ] && { warn "node missing (check-only)"; return; }
        warn "node not found — install Node >= 20 (nvm, fnm, or distro package)"
    fi
    if have corepack; then
        [ "$CHECK_ONLY" -eq 1 ] || corepack enable >/dev/null 2>&1 || true
        log "corepack enabled (yarn via packageManager field)"
    fi
}

# ---------------------------------------------------------------------------
# 3. Bazel (meta build orchestrator).
# ---------------------------------------------------------------------------
ensure_bazel() {
    if have bazelisk || have bazel; then
        log "bazel present"
    else
        warn "bazel/bazelisk not found — optional for Cargo+Vite dev, required for hermetic release builds"
    fi
}

# ---------------------------------------------------------------------------
# 4. Upstream engine sources: Chromium (depot_tools) + Gecko (mach bootstrap).
#    These are huge (>40 GB). We provide a working fetch shim, not a stub.
# ---------------------------------------------------------------------------
fetch_engine() {
    [ "$FETCH_ENGINE" -eq 0 ] && { log "Skipping engine fetch (--no-engine)"; return; }
    [ "$CHECK_ONLY" -eq 1 ] && { log "Skipping engine fetch (--check)"; return; }

    mkdir -p "$ROOT/third_party"

    # Chromium via depot_tools.
    if [ ! -d "$ROOT/third_party/depot_tools" ]; then
        log "Cloning depot_tools"
        git clone --depth 1 \
            https://chromium.googlesource.com/chromium/tools/depot_tools.git \
            "$ROOT/third_party/depot_tools"
    fi
    if [ ! -d "$ROOT/third_party/chromium/src" ]; then
        warn "Chromium source not present. To fetch (~40 min, ~100 GB):"
        warn "  export PATH=\"$ROOT/third_party/depot_tools:\$PATH\""
        warn "  mkdir -p $ROOT/third_party/chromium && cd \$_ && fetch --nohooks chromium"
        warn "Skipping automatic Chromium fetch to avoid surprising disk usage."
        warn "Run: ./tools/repro-build/fetch-chromium.sh   to perform it explicitly."
    fi

    # Gecko via mach bootstrap.
    if [ ! -d "$ROOT/third_party/gecko" ]; then
        warn "Gecko source not present. To fetch:"
        warn "  ./tools/repro-build/fetch-gecko.sh"
    fi
}

ensure_rust
ensure_node
ensure_bazel
fetch_engine

if [ "$CHECK_ONLY" -eq 1 ]; then
    log "Environment check complete."
else
    log "Bootstrap complete. Next: ./build all"
fi
