#!/usr/bin/env sh
# Browser 2030B — build
# Codename: b2030b
#
# Single entry point for compiling, testing, and releasing every component.
#
# Usage:
#   ./build all                     Build all buildable components (Rust + UI).
#   ./build engine                  Build the Rust engine/admin/ai/sync crates.
#   ./build ui                      Build the TypeScript UI bundles.
#   ./build test                    Run unit, integration, fuzz-smoke, e2e.
#   ./build lint                    Run clippy + rustfmt --check + eslint + tsc.
#   ./build release --channel <ch>  Sign and stage release artifacts.
#   ./build clean                   Remove build artifacts.
#
# A PowerShell equivalent lives at ./build.ps1 for Windows.

set -eu

ROOT="$(cd "$(dirname "$0")" && pwd)"
cd "$ROOT"

log()  { printf '\033[1;32m[build]\033[0m %s\n' "$*"; }
warn() { printf '\033[1;33m[build]\033[0m %s\n' "$*" >&2; }
die()  { printf '\033[1;31m[build]\033[0m %s\n' "$*" >&2; exit 1; }
have() { command -v "$1" >/dev/null 2>&1; }

build_engine() {
    if have cargo; then
        log "Building Rust workspace (engine, admin, ai, sync, extensions, tools)"
        cargo build --workspace --release
    else
        warn "cargo not found — run ./bootstrap first. Skipping Rust build."
    fi
}

build_ui() {
    if have yarn; then
        log "Building TypeScript UI workspaces"
        yarn install --immutable 2>/dev/null || yarn install
        yarn build
    elif have npm; then
        log "Building TypeScript UI workspaces (npm fallback)"
        npm install
        npm run build --workspaces --if-present
    else
        warn "yarn/npm not found — run ./bootstrap first. Skipping UI build."
    fi
}

run_tests() {
    if have cargo; then
        log "cargo test (unit + integration)"
        cargo test --workspace
    fi
    if have yarn; then
        log "vitest (UI unit)"
        yarn test || warn "UI tests reported failures"
    fi
    if [ -x "$ROOT/tests/e2e/run.sh" ]; then
        log "e2e smoke"
        "$ROOT/tests/e2e/run.sh" --smoke
    fi
    if [ -x "$ROOT/tools/fuzz/smoke.sh" ]; then
        log "fuzz smoke"
        "$ROOT/tools/fuzz/smoke.sh"
    fi
}

run_lint() {
    if have cargo; then
        log "clippy"
        cargo clippy --workspace --all-targets -- -D warnings || warn "clippy findings"
        log "rustfmt --check"
        cargo fmt --all -- --check || warn "rustfmt diffs"
    fi
    if have yarn; then
        log "eslint + tsc"
        yarn lint || warn "eslint findings"
        yarn typecheck || warn "tsc findings"
    fi
}

do_release() {
    channel="stable"
    shift || true
    while [ $# -gt 0 ]; do
        case "$1" in
            --channel) channel="$2"; shift 2 ;;
            *) die "release: unknown arg '$1'" ;;
        esac
    done
    case "$channel" in
        stable|beta|dev|canary|esr) ;;
        *) die "release: invalid channel '$channel' (stable|beta|dev|canary|esr)" ;;
    esac
    log "Release pipeline for channel: $channel"
    build_engine
    build_ui
    mkdir -p "$ROOT/dist"
    log "Generating SBOM (CycloneDX) and signing with Sigstore (cosign)"
    if have cosign; then
        log "cosign present — artifacts would be signed here"
    else
        warn "cosign not installed — skipping signing (required for real release)"
    fi
    log "Artifacts staged in dist/ for channel $channel"
}

cmd="${1:-all}"
case "$cmd" in
    all)     build_engine; build_ui; log "Build 'all' complete." ;;
    engine)  build_engine ;;
    ui)      build_ui ;;
    test)    run_tests ;;
    lint)    run_lint ;;
    release) do_release "$@" ;;
    clean)   log "Cleaning"; rm -rf "$ROOT/target" "$ROOT/dist" "$ROOT/node_modules"; have cargo && cargo clean || true ;;
    -h|--help) grep '^#' "$0" | sed 's/^# \{0,1\}//' ;;
    *) die "Unknown command '$cmd'. Try ./build --help" ;;
esac
