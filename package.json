{
  "name": "b2030b",
  "version": "0.1.0",
  "private": true,
  "description": "Browser 2030B — next-generation web browser monorepo (JS/TS workspaces)",
  "license": "LicenseRef-Browser2030B-1.0",
  "packageManager": "yarn@4.5.0",
  "workspaces": [
    "ui/shell-desktop",
    "ui/command-palette",
    "ui/devtools",
    "ui/reader",
    "ui/pip",
    "extensions/store-client",
    "cloud/wasm-edition"
  ],
  "scripts": {
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc -b --pretty",
    "test": "vitest run",
    "build": "yarn workspaces foreach -At run build",
    "dev:shell": "yarn workspace @b2030b/shell-desktop dev"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "eslint": "^9.9.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
